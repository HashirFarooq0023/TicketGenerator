<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
</head>

<body>
    <%- include('partials/header') %>

    <main class="container">
        <section class="animate-fade-in-up">
            <h1 style="font-size: 3.5rem; margin-bottom: 2rem;">Discover Our <span class="gradient-text">Story.</span></h1>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
                <div>
                    <p style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
                        The IT Support Team was established with a clear goal: to provide seamless tech integration for modern businesses. We believe that technology should empower your work, not hinder it.
                    </p>
                    <p style="font-size: 1.1rem; color: var(--text-secondary);">
                        Our team consists of certified engineers and reactive support specialists who provide 24/7 monitoring and maintenance for your entire digital ecosystem.
                    </p>
                </div>
                <div class="glass-card" style="padding: 3rem; text-align: center;">
                    <h2 class="gradient-text" style="font-size: 3rem; margin-bottom: 0.5rem;">24/7</h2>
                    <p style="font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary);">Active Support</p>
                </div>
            </div>
        </section>

        <section style="background: var(--bg-secondary); border-radius: 2rem; padding: 4rem; margin-bottom: 5rem;">
            <div style="text-align: center; max-width: 800px; margin: 0 auto;">
                <h2 style="font-size: 2.5rem; margin-bottom: 1.5rem;">Our <span class="gradient-text">Mission</span></h2>
                <p style="font-size: 1.25rem; font-weight: 500; color: var(--text-primary);">
                    "To provide rock-solid IT infrastructure and support that allows your business to innovate without interruption."
                </p>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>
</body>

</html>
