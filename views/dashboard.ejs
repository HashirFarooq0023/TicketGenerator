<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
    <style>
        .badge-status {
            padding: 0.25rem 0.6rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        .status-open {
            background: rgba(168, 85, 247, 0.15);
            color: var(--accent-secondary);
            border: 1px solid rgba(168, 85, 247, 0.3);
        }
        .status-progress {
            background: rgba(245, 158, 11, 0.15);
            color: #fbbf24;
            border: 1px solid rgba(245, 158, 11, 0.3);
        }
        .status-resolved {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        
        .badge-priority {
            padding: 0.25rem 0.6rem;
            border-radius: 0.375rem;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .priority-high {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .priority-medium {
            background: rgba(99, 102, 241, 0.15);
            color: #818cf8;
            border: 1px solid rgba(99, 102, 241, 0.3);
        }
        .priority-low {
            background: rgba(148, 163, 184, 0.15);
            color: #cbd5e1;
            border: 1px solid rgba(148, 163, 184, 0.3);
        }
        
        .ticket-item {
            border-bottom: 1px solid var(--glass-border);
            padding: 1.5rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ticket-item:last-child {
            border-bottom: none;
        }
        .dashboard-grid {
            display: grid;
            grid-template-columns: <%= user.role === 'admin' ? '280px 1fr' : '1fr 1fr' %>;
            gap: 2.5rem;
            margin-top: 2rem;
        }
        @media (max-width: 900px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

        <main class="container" style="max-width: 1600px; padding: 3rem 1.5rem;">
            <!-- Internet Warning Banner -->
            <div style="background: rgba(99, 102, 241, 0.05); border: 1px solid var(--glass-border); border-radius: 0.75rem; padding: 0.75rem 1.25rem; font-size: 0.85rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; animation: fadeInUp 0.8s ease-out forwards;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-primary); flex-shrink: 0;"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20" stroke-width="3"></line></svg>
                <span><strong>Network Tip:</strong> Please make sure your internet connection is turned on to synchronize with the MongoDB Atlas cloud database.</span>
            </div>

            <% if (locals.error) { %>
                <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #f87171; padding: 0.75rem 1rem; border-radius: 0.5rem; margin-bottom: 2rem; font-size: 0.9rem;">
                    <%= error %>
                </div>
            <% } %>
            
            <% if (locals.message) { %>
                <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); color: #34d399; padding: 0.75rem 1rem; border-radius: 0.5rem; margin-bottom: 2rem; font-size: 0.9rem;">
                    <%= message %>
                </div>
            <% } %>

            <div class="animate-fade-in-up">
                <h1>Helpdesk <span class="gradient-text">Dashboard</span></h1>
                <p style="color: var(--text-secondary); margin-bottom: 1rem;">
                    <%= user.role === 'admin' ? 'System Support Ticket Queue (All Tickets)' : 'Manage and track your submitted tickets.' %>
                </p>
            </div>

            <div class="dashboard-grid animate-fade-in-up">
                <!-- Left Column: Submit Ticket / User Info -->
                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <!-- Profile Info Card -->
                    <div class="glass-card" style="padding: 1.5rem;">
                        <h3 style="margin-bottom: 1rem;">Profile Info</h3>
                        <div style="font-size: 0.95rem; display: flex; flex-direction: column; gap: 0.5rem;">
                            <p style="color: var(--text-secondary);">Name: <strong style="color: var(--text-primary);"><%= user.name %></strong></p>
                            <p style="color: var(--text-secondary);">Email: <strong style="color: var(--text-primary);"><%= user.email %></strong></p>
                            <p style="color: var(--text-secondary);">Role: 
                                <span style="font-size: 0.75rem; background: var(--glass-border); padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-weight: bold; text-transform: uppercase; color: var(--text-primary);">
                                    <%= user.role %>
                                </span>
                            </p>
                        </div>
                    </div>

                    <!-- Create Ticket Card -->
                    <% if (user.role !== 'admin') { %>
                    <div class="glass-card">
                        <h3 style="margin-bottom: 1.5rem;">Create a Support Ticket</h3>
                        <form action="/tickets" method="POST">
                            <div class="form-group">
                                <label for="title">Issue Subject</label>
                                <input type="text" id="title" name="title" placeholder="e.g. WiFi Disconnects constantly" required>
                            </div>
                            <div class="form-group">
                                <label for="priority">Priority</label>
                                <select id="priority" name="priority" style="width: 100%; padding: 0.75rem 1rem; background: var(--bg-secondary); border: 1px solid var(--glass-border); border-radius: 0.5rem; color: white; font-family: inherit; outline: none;">
                                    <option value="Low">Low</option>
                                    <option value="Medium" selected>Medium</option>
                                    <option value="High">High</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="roomNumber">Lab / Room Number</label>
                                <input type="text" id="roomNumber" name="roomNumber" placeholder="e.g. A-CL-400, CL203, A204">
                            </div>
                            <div class="form-group">
                                <label for="description">Detailed Description</label>
                                <textarea id="description" name="description" rows="4" placeholder="Provide details about the issue..." required></textarea>
                            </div>
                            <button type="submit" class="btn-primary" style="width: 100%;">Create Ticket</button>
                        </form>
                    </div>
                    <% } %>
                </div>

                <!-- Right Column: Tickets Queue -->
                <div class="glass-card">
                    <h2 style="margin-bottom: 1.5rem;"><%= user.role === 'admin' ? 'Ticket Queue' : 'My Support Tickets' %></h2>
                    
                    <% if (tickets.length === 0) { %>
                        <div style="text-align: center; padding: 4rem 0;">
                            <p style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 1rem;">No tickets found.</p>
                            <p style="font-size: 0.9rem; color: var(--text-secondary);">Submit a new ticket using the form on the left.</p>
                        </div>
                    <% } else { %>
                        <div style="display: flex; flex-direction: column;">
                            <% tickets.forEach(ticket => { %>
                                <div class="ticket-item">
                                    <div style="padding-right: 1.5rem;">
                                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
                                            <h4 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary);"><%= ticket.title %></h4>
                                            
                                            <!-- Status Badge -->
                                            <% if (ticket.status === 'Open') { %>
                                                <span class="badge-status status-open">Open</span>
                                            <% } else if (ticket.status === 'In Progress') { %>
                                                <span class="badge-status status-progress">In Progress</span>
                                            <% } else { %>
                                                <span class="badge-status status-resolved">Resolved</span>
                                            <% } %>

                                            <!-- Priority Badge -->
                                            <% if (ticket.priority === 'High') { %>
                                                <span class="badge-priority priority-high">High</span>
                                            <% } else if (ticket.priority === 'Low') { %>
                                                <span class="badge-priority priority-low">Low</span>
                                            <% } else { %>
                                                <span class="badge-priority priority-medium">Medium</span>
                                            <% } %>

                                            <!-- Location Badge -->
                                            <% if (ticket.roomNumber) { %>
                                                <span style="font-size: 0.75rem; font-weight: 600; background: rgba(99, 102, 241, 0.15); color: #a5b4fc; border: 1px solid rgba(99, 102, 241, 0.3); padding: 0.25rem 0.6rem; border-radius: 50px; text-transform: uppercase; display: inline-flex; align-items: center; gap: 0.25rem;">
                                                    📍 <%= ticket.roomNumber %>
                                                </span>
                                            <% } %>
                                        </div>
                                        <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            <%= ticket.description %>
                                        </p>
                                        <div style="font-size: 0.8rem; color: var(--text-secondary);">
                                            <span>Submitted <%= new Date(ticket.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' }) %></span>
                                            <% if (user.role === 'admin' && ticket.createdBy) { %>
                                                <span> by <strong><%= ticket.createdBy.name %></strong> (<%= ticket.createdBy.email %>)</span>
                                            <% } %>
                                        </div>
                                    </div>
                                    <div style="display: flex; gap: 0.5rem; align-items: center; flex-shrink: 0;">
                                        <% if (ticket.status !== 'Resolved') { %>
                                            <form action="/tickets/<%= ticket._id %>/update" method="POST" style="display: inline;">
                                                <input type="hidden" name="status" value="Resolved">
                                                <button type="submit" class="btn-primary" style="font-size: 0.75rem; padding: 0.4rem 0.8rem; background: rgba(16, 185, 129, 0.15); border: 1px solid rgba(16, 185, 129, 0.3); color: #34d399;">Resolve</button>
                                            </form>
                                        <% } %>
                                        <a href="/tickets/<%= ticket._id %>/edit" class="btn-primary" style="font-size: 0.75rem; padding: 0.4rem 0.8rem; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--glass-border); text-decoration: none;">Edit</a>
                                        <form action="/tickets/<%= ticket._id %>/delete" method="POST" style="display: inline;">
                                            <button type="submit" class="btn-primary" style="font-size: 0.75rem; padding: 0.4rem 0.8rem; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #f87171;">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>
