<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('partials/head') %>
</head>

<body>
    <%- include('partials/header') %>

        <main class="container">
            <section class="animate-fade-in-up">
                <div style="text-align: center; margin-bottom: 4rem;">
                    <h1 style="font-size: 3.5rem; margin-bottom: 1rem;">Let's <span
                            class="gradient-text">Connect.</span></h1>
                    <p style="color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Have a technical issue or
                        need to discuss infrastructure? Our IT Support Team is ready to help.</p>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem;">
                    <div class="glass-card">
                        <h2 style="margin-bottom: 2rem;">Helpdesk Info</h2>
                        <div style="margin-bottom: 2rem;">
                            <p
                                style="color: var(--accent-primary); font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">
                                Direct Assistance</p>
                            <p style="font-size: 1.1rem;">support@ucp.edu.pk</p>
                        </div>
                        <div style="margin-bottom: 2rem;">
                            <p
                                style="color: var(--accent-primary); font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">
                                Main Office</p>
                            <p style="font-size: 1.1rem;">Johar Town ,Lahore ,Punjab </p>
                        </div>
                        <div>
                            <p
                                style="color: var(--accent-primary); font-weight: 600; font-size: 0.8rem; text-transform: uppercase;">
                                Helpdesk Hours</p>
                            <p style="font-size: 1.1rem;">24/7 Monitoring & Emergency Support</p>
                        </div>
                    </div>

                    <div class="glass-card">
                        <form action="#" method="POST">
                            <div class="form-group">
                                <label for="name">Employee Name</label>
                                <input type="text" id="name" name="name" placeholder="Ali Raza , Kashif ...." required>
                            </div>
                            <div class="form-group">
                                <label for="email">Work Email</label>
                                <input type="email" id="email" name="email" placeholder="AliRaza1122@gmail.com"
                                    required>
                            </div>
                            <div class="form-group">
                                <label for="subject">Issue Subject</label>
                                <input type="text" id="subject" name="subject"
                                    placeholder="Network Problem / Access Request" required>
                            </div>
                            <div class="form-group">
                                <label for="message">Issue Details</label>
                                <textarea id="message" name="message" rows="5"
                                    placeholder="Please describe the technical issue..." required></textarea>
                            </div>
                            <button type="submit" class="btn-primary" style="width: 100%;">Send Message</button>
                        </form>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>
</body>

</html>